{
  "name": "termfolio-quality",
  "private": true,
  "description": "Development-only quality checks for the Termfolio Hugo theme.",
  "engines": {
    "node": "24.18.0",
    "npm": "11.16.0"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "check": "npm run lint:markdown && npm run check:links",
